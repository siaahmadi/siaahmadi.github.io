  html              = {https://journals.aps.org/pr/abstract/10.1103/PhysRev.47.777},
  pdf               = {example_pdf.pdf},
  altmetric         = {248277},
  dimensions        = {true},
  google_scholar_id = {qyhmnyLat1gC},

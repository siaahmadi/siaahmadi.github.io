@article{ahmadi2025distinct,
  title             = "Distinct roles of dentate gyrus and medial entorhinal cortex inputs for phase precession and temporal correlations in the hippocampal {CA3} area",
  author            = "Ahmadi, Siavash and Sasaki, Takuya and Sabariego, Marta and Leibold, Christian and Leutgeb, Stefan and Leutgeb, Jill K",
  abstract          = "The hippocampal CA3 subregion is a densely connected recurrent circuit that supports memory by generating and storing sequential neuronal activity patterns that reflect recent experience. While theta phase precession is thought to be critical for generating sequential activity during memory encoding, the circuit mechanisms that support this computation across hippocampal subregions are unknown. By analyzing CA3 network activity in the absence of each of its theta-modulated external excitatory inputs, we show necessary and unique contributions of the dentate gyrus (DG) and the medial entorhinal cortex (MEC) to phase precession. DG inputs are essential for preferential spiking of CA3 cells during late theta phases and for organizing the temporal order of neuronal firing, while MEC inputs sharpen the temporal precision throughout the theta cycle. A computational model that accounts for empirical findings suggests that the unique contribution of DG inputs to theta-related spike timing is supported by targeting precisely timed inhibitory oscillations. Our results thus identify a novel and unique functional role of the DG for sequence coding in the CA3 circuit.",
  journal           = "Nature Communications",
  volume            =  16,
  number            =  1,
  pages             = "13",
  year              = {2025},
  month             = {Jan},
  publisher         = {Springer Nature},
  doi               = {10.1038/s41467-024-54943-2},
  url               = {https://doi.org/10.1038/s41467-024-54943-2},
  html              = {https://doi.org/10.1038/s41467-024-54943-2},
  pdf               = {s41467-024-54943-2.pdf},
  altmetric         = {172642905},
  dimensions        = {true},
  google_scholar_id = {R3hNpaxXUhUC},
  video             = {https://www.youtube-nocookie.com/embed/aqz-KE-bpKQ},
  additional_info   = {. *More Information* can be [found here](https://github.com/alshedivat/al-folio/)},
  annotation        = {* Example use of superscripts<br>† Albert Einstein},
  selected          = {true},
}

@article{sasaki2018dentate,
  title             = "Dentate network activity is necessary for spatial working memory by supporting CA3 sharp-wave ripple generation and prospective firing of CA3 neurons",
  author            = "Sasaki, Takuya and Piatti, Verónica C and Hwaun, Ernie and Ahmadi, Siavash and Lisman, John E and Leutgeb, Stefan and Leutgeb, Jill K",
  abstract          = "Complex spatial working memory tasks have been shown to require both hippocampal sharp-wave ripple (SWR) activity and dentate gyrus (DG) neuronal activity. We therefore asked whether DG inputs to CA3 contribute to spatial working memory by promoting SWR generation. Recordings from DG and CA3 while rats performed a dentate-dependent working memory task on an eight-arm radial maze revealed that the activity of dentate neurons and the incidence rate of SWRs both increased during reward consumption. We then found reduced reward-related CA3 SWR generation without direct input from dentate granule neurons. Furthermore, CA3 cells with place fields in not-yet-visited arms preferentially fired during SWRs at reward locations, and these prospective CA3 firing patterns were more pronounced for correct trials and were dentate-dependent. These results indicate that coordination of CA3 neuronal activity patterns by DG is necessary for the generation of neuronal firing patterns that support goal-directed behavior and memory.",
  journal           = "Nature Neuroscience",
  volume            =  21,
  number            =  2,
  pages             = "258--269",
  year              = {2018},
  month             = {Feb},
  publisher         = {Springer Nature},
  doi               = {10.1038/s41593-017-0061-5},
  url               = {https://doi.org/10.1038/s41593-017-0061-5},
  html              = {https://doi.org/10.1038/s41593-017-0061-5},
  pdf               = {s41593-017-0061-5.pdf},
  altmetric         = {31716412},
  dimensions        = {true},
  google_scholar_id = {u5HHmVD_uO8C},
  video             = {https://www.youtube-nocookie.com/embed/aqz-KE-bpKQ},
  additional_info   = {. *More Information* can be [found here](https://github.com/alshedivat/al-folio/)},
  annotation        = {* Example use of superscripts<br>† Albert Einstein},
  selected          = {true},
}

@article{sabariego2019time,
  title             = "Time cells in the Hippocampus are neither dependent on medial Entorhinal cortex inputs nor necessary for spatial working memory",
  author            = "Sabariego, Marta and Schönwald, Antonia and Boublil, Brittney L and Zimmerman, David T and Ahmadi, Siavash and Gonzalez, Nailea and Leibold, Christian and Clark, Robert E and Leutgeb, Jill K and Leutgeb, Stefan",
  abstract          = "A key function of the hippocampus and entorhinal cortex is to bridge events that are discontinuous in time, and it has been proposed that medial entorhinal cortex (mEC) supports memory retention by sustaining the sequential activity of hippocampal time cells. Therefore, we recorded hippocampal neuronal activity during spatial working memory and asked whether time cells depend on mEC inputs. Working memory was impaired in rats with mEC lesions, but the occurrence of time cells and of trajectory-coding cells in the stem did not differ from controls. Rather, the main effect of mEC lesions was an extensive spatial coding deficit of CA1 cells, which included inconsistency over time and reduced firing differences between positions on the maze. Therefore, mEC is critical for providing stable and distinct spatial information to hippocampus, while working memory (WM) maintenance is likely supported either by local synaptic plasticity in hippocampus or by activity patterns elsewhere in the brain.",
  journal           = "Neuron",
  volume            =  102,
  number            =  6,
  pages             = "1235--1248.e5",
  year              = {2019},
  month             = {Jun},
  publisher         = {Cell Press},
  doi               = {10.1016/j.neuron.2019.04.005},
  url               = {https://doi.org/10.1016/j.neuron.2019.04.005},
  html              = {https://doi.org/10.1016/j.neuron.2019.04.005},
  pdf               = {PIIS089662731930340X.pdf},
  dimensions        = {true},
  google_scholar_id = {9yKSN-GCB0IC},
  video             = {https://www.youtube-nocookie.com/embed/aqz-KE-bpKQ},
  additional_info   = {. *More Information* can be [found here](https://github.com/alshedivat/al-folio/)},
  annotation        = {* Example use of superscripts<br>† Albert Einstein},
  selected          = {true},
}

@article{ahmadi2025multiple,
  title             = "Multiple long timescale computations underlie strategic turn taking in primates",
  author            = "Ahmadi, Siavash and Haroush, Keren",
  abstract          = "Successful social exchanges, from date nights to peace talks, fundamentally rely on coordination of conflicting goals or preferences. Such conflicts can be harmonized by long-time-scale strategies, such as turn-taking behaviors, however, these strategies are commonly impaired in psychiatric disorders. Despite the importance of strategic social coordination to both normal and abnormal cognition and societal integrity, its single-neuronal basis remains elusive. Here, we leverage game theory to operationalize long-term strategic coordination and dissect the computations underlying turn-taking in non-human primates. We find that monkeys can take turns and coordinate outcomes contrary to their preference. Remarkably, cingulate neurons were able to extract and encode not just instantaneous task-related information, but rather multiple, varied high-order complex features, dissociated from sensory/motor information, such as the length of the current turn and overall reward disparity over the entire session. Lastly, we show that selfish behavior is associated with poor tracking of inequity in cingulate single-neurons and populations. Our findings uncover for the first time the precision with which neurons distill dynamic, long timescale, mixed concrete-and-abstract representations of past experiences likely underlying multiple complex cognitive processes.",
  journal           = "Cell",
  year              = {2025},
  publisher         = {Cell Press},
  dimensions        = {true},
  video             = {https://www.youtube-nocookie.com/embed/aqz-KE-bpKQ},
  additional_info   = {. *More Information* can be [found here](https://github.com/alshedivat/al-folio/)},
  annotation        = {* Example use of superscripts<br>† Albert Einstein},
  selected          = {true},
}

@preprint{ahmadi2025distributed,
  title             = "Distributed Counterfactual Reward Signaling for Policy Refinement in Multi-Agent Settings",
  author            = "Ahmadi, Siavash and Haroush, Keren",
  abstract          = "In dynamic social interactions where rewards depend not only on an agent's own actions but also on those of the others, animals must rapidly adjust their actions to satisfy potentially conflicting preferences. Mental simulation of counterfactual outcomes---rewards that would have resulted from actions \emph{not} taken---can support more efficient policy updating by allowing agents to learn from hypothetical experiences. While such mechanisms have been explored in artificial reinforcement learning systems, their biological basis in social settings remains poorly understood. Here, we adapt a game-theoretic paradigm---the iterated Battle of the Sexes (iBOS)---for neurophysiology to study how macaques make decisions under structured preference conflict. We report that the ventrolateral prefrontal cortex (vlPFC) encodes agent-specific counterfactual rewards and exchanges these signals bidirectionally with the dorsal anterior cingulate cortex (dACC) with an asymmetric temporal organization across task epochs. By dissociating decision variables from the simultaneously represented memory traces, we then show that this information flow in the vlPFC-dACC circuit can partially explain shifts in the representation of behavioral strategies. These findings uncover a distributed, temporally structured neural architecture for counterfactual reward processing in social decision-making, with implications for models of adaptive behavior in multi-agent environments.",
  journal           = "Preprint",
  publisher         = {Unpublished manuscript},
  year              = {2025},
  dimensions        = {true},
  video             = {https://www.youtube-nocookie.com/embed/aqz-KE-bpKQ},
  additional_info   = {. *More Information* can be [found here](https://github.com/alshedivat/al-folio/)},
  annotation        = {* Example use of superscripts<br>† Albert Einstein},
  selected          = {true},
}



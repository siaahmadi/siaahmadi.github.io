@unpublished{ahmadi2026scaling,
  title             = "Strong Scaling of Autoregressive Inference",
  author            = "Ahmadi, Siavash",
  abstract          = "The impressive capabilities of modern large language models critically rely on generating responses autoregressively. Autoregressive token generation properly factorizes the joint probability distribution of the output which enables superior response quality. However, following the correct statistical distribution of tokens as such destines generation to be inherently sequential, bottlenecking scaling. Efforts to overcome this have largely fallen short because they fail to preserve the output's \emph{joint distribution}. Here, we factorize autoregressive generation into a latent graphical model to enable \emph{strong} inference scaling. Our scheme leads to a theoretical \emph{quadratic} speedup. We present preliminary empirical results that this amounts to a up to over 20x faster wall clock generation time for typical-length outputs on an entry level T4 GPU at the expense of potentially more costly training. Our method's significant gains could empower better reasoning models wherein a large number of chain-of-thought tokens must be generated fast. Furthermore, because of its strong scaling nature and that it preserves the autoregressive property, it can be combined with established methods designed to expedite AR generation to accelerate inference even more.",
  journal           = "Preprint",
  publisher         = {Working paper},
  year              = {2026},
  dimensions        = {true},
  additional_info   = {. *More Information* can be [found here](https://github.com/alshedivat/al-folio/)},
  annotation        = {* Example use of superscripts<br>† Albert Einstein},
  selected          = {true},
}
